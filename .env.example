# Database (SQLite for local / simple hosting; MySQL/Postgres for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Buy Software | Auctions Evtinko Ltd."
NEXT_PUBLIC_COMPANY_NAME="Auctions Evtinko Ltd."
NEXT_PUBLIC_DOMAIN="buy-software.evtinko-bg.com"

# Admin seed (created on first db:seed)
ADMIN_EMAIL="admin@evtinko-bg.com"
ADMIN_PASSWORD="ChangeMeAdmin123!"

# Stripe (credit / debit cards) — https://dashboard.stripe.com
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# PayPal — https://developer.paypal.com
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

# ePay.bg — https://www.epay.bg
EPAY_MIN="YOUR_MIN"
EPAY_SECRET="YOUR_EPAY_SECRET"
EPAY_URL="https://www.epay.bg/"
EPAY_CIN="YOUR_CIN"

# Demo payments (auto-approve without real gateways — disable in production)
ENABLE_DEMO_PAYMENTS="true"

# Upload storage path (absolute or relative to project root)
UPLOAD_DIR="./uploads"

# Email (SMTP). If empty — emails saved to data/mail-outbox/
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"Auctions Evtinko Ltd.\" <noreply@evtinko-bg.com>"

# Social login (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Display FX: 1 EUR = ? USD (BGN is fixed at 1.95583)
NEXT_PUBLIC_EUR_USD_RATE="1.08"
EUR_USD_RATE="1.08"

